/**
 * 备件管理系统 — 全局样式
 */

page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  /* 为自定义 tabBar 预留底部空间 */
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* ── 通用容器 ── */
.container {
  padding: 24rpx;
}

/* ── 卡片 ── */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

/* ── 状态标签 ── */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.tag-approved {
  background: #f6ffed;
  color: #52c41a;
}

.tag-rejected {
  background: #fff1f0;
  color: #f5222d;
}

.tag-cancelled {
  background: #f5f5f5;
  color: #999;
}

.tag-in-stock {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-out-stock {
  background: #f5f5f5;
  color: #999;
}

/* ── 表单 ── */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1890ff;
}

/* ── 按钮 ── */
.btn-primary {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

.btn-primary[disabled] {
  background: #b3d9ff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.btn-default {
  background: #fff;
  color: #333;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 30rpx;
}

/* ── 空状态 ── */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
}

/* ── 加载 ── */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* ── 列表项 ── */
.list-item {
  background: #fff;
  padding: 24rpx;
  margin-bottom: 2rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.list-item-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.list-item-extra {
  font-size: 24rpx;
  color: #999;
}

/* ── 搜索栏 ── */
.search-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

/* ── 筛选 ── */
.filter-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.filter-item {
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: #f5f5f5;
  color: #666;
}

.filter-item.active {
  background: #e6f7ff;
  color: #1890ff;
}
