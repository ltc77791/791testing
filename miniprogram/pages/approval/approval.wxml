<!--
  审批页 — 待审批列表 + 审批/驳回（含部分批准）
-->
<view>
  <!-- 状态筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{statusFilter === 'pending' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="pending">待审批</view>
    <view class="filter-item {{statusFilter === 'approved' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="approved">已通过</view>
    <view class="filter-item {{statusFilter === 'rejected' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="rejected">已驳回</view>
    <view class="filter-item {{statusFilter === '' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="">全部</view>
  </view>

  <!-- 列表 -->
  <view wx:for="{{items}}" wx:key="_id" class="card" bindtap="onTapRequest" data-id="{{item._id}}">
    <view style="display: flex; justify-content: space-between; align-items: center;">
      <view>
        <text style="font-weight: 600;">{{item.applicant}}</text>
        <view class="tag tag-{{item.status}}" style="margin-left: 12rpx;">{{item.statusLabel}}</view>
      </view>
      <text style="font-size: 24rpx; color: #999;">{{item.createdAtText}}</text>
    </view>
    <view style="margin-top: 12rpx;">
      <view wx:for="{{item.items}}" wx:for-item="sub" wx:key="part_no" style="font-size: 26rpx; color: #666;">
        {{sub.part_name}} x {{sub.quantity}}
      </view>
    </view>
    <view style="font-size: 24rpx; color: #999; margin-top: 8rpx;">项目: {{item.project_location}} | 原因: {{item.outbound_reason || '-'}}</view>
  </view>

  <view wx:if="{{!loading && items.length === 0}}" class="empty">
    <view class="empty-text">暂无{{statusFilter === 'pending' ? '待审批' : ''}}申请</view>
  </view>
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 审批弹窗 -->
  <view wx:if="{{showApprovalDialog}}" class="dialog-mask" bindtap="closeDialog">
    <view class="dialog-content" catchtap="noop" style="max-height: 85vh; overflow-y: auto;">
      <view class="card-title">审批详情</view>

      <view style="margin-bottom: 16rpx;">
        <text style="color: #999;">申请人: </text>
        <text>{{currentRequest.applicant}}</text>
      </view>
      <view style="margin-bottom: 16rpx;">
        <text style="color: #999;">项目: </text>
        <text>{{currentRequest.project_location}}</text>
      </view>
      <view style="margin-bottom: 16rpx;">
        <text style="color: #999;">出库原因: </text>
        <text>{{currentRequest.outbound_reason || '-'}}</text>
      </view>

      <view style="margin-bottom: 16rpx;">
        <text style="color: #999;">申请明细:</text>
        <view wx:for="{{currentRequest.items}}" wx:for-item="sub" wx:key="part_no" style="padding: 4rpx 0; font-size: 26rpx;">
          {{sub.part_name}} ({{sub.part_no}}) x {{sub.quantity}}
        </view>
      </view>

      <block wx:if="{{currentRequest.status === 'pending'}}">
        <!-- 审批模式切换 -->
        <view style="margin-bottom: 20rpx;">
          <view style="font-size: 28rpx; font-weight: 600; margin-bottom: 12rpx;">审批模式</view>
          <view style="display: flex; gap: 16rpx;">
            <view
              class="mode-btn {{approveMode === 'full' ? 'mode-btn-active' : ''}}"
              bindtap="onApproveModeChange"
              data-mode="full"
            >全部批准</view>
            <view
              class="mode-btn {{approveMode === 'partial' ? 'mode-btn-active' : ''}}"
              bindtap="onApproveModeChange"
              data-mode="partial"
            >部分批准</view>
          </view>
        </view>

        <!-- 部分批准：序列号选择/数量输入 -->
        <block wx:if="{{approveMode === 'partial'}}">
          <view style="margin-bottom: 20rpx;">
            <view wx:for="{{approveItems}}" wx:key="part_no" wx:for-index="itemIdx" style="margin-bottom: 16rpx; padding: 16rpx; background: #f9f9f9; border-radius: 8rpx;">
              <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx;">
                <view style="font-size: 28rpx; font-weight: 600;">{{item.part_name}} ({{item.part_no}})</view>
                <!-- 高价值：全选/取消全选按钮 -->
                <view wx:if="{{!item.isLowValue}}" style="font-size: 24rpx; color: #1890ff;" bindtap="onToggleAllSN" data-item-idx="{{itemIdx}}">
                  {{item.selected_sns.length === item.serial_numbers.length ? '取消全选' : '全选'}}
                </view>
              </view>

              <!-- 低价值备件：数量输入 -->
              <block wx:if="{{item.isLowValue}}">
                <view style="font-size: 24rpx; color: #999; margin-bottom: 8rpx;">低价值备件，按数量审批</view>
                <view style="display: flex; align-items: center; gap: 12rpx;">
                  <text style="font-size: 26rpx;">批准数量:</text>
                  <input type="number" class="form-input" style="width: 160rpx; text-align: center;" value="{{item.approve_qty}}" bindinput="onApproveQtyInput" data-item-idx="{{itemIdx}}" />
                  <text style="font-size: 24rpx; color: #999;"> / {{item.quantity}}</text>
                </view>
              </block>

              <!-- 高价值备件：序列号选择 -->
              <block wx:else>
                <view style="font-size: 24rpx; color: #999; margin-bottom: 8rpx;">
                  已选 {{item.selected_sns.length}} / {{item.serial_numbers.length}}
                </view>
                <view style="display: flex; flex-wrap: wrap; gap: 8rpx;">
                  <view
                    wx:for="{{item.serial_numbers}}"
                    wx:for-item="sn"
                    wx:key="*this"
                    class="sn-chip {{item.selected_map[sn] ? 'sn-chip-selected' : ''}}"
                    bindtap="onToggleSN"
                    data-item-idx="{{itemIdx}}"
                    data-sn="{{sn}}"
                  >{{sn}}</view>
                </view>
              </block>
            </view>
          </view>
        </block>

        <!-- 全部批准提示 -->
        <block wx:if="{{approveMode === 'full'}}">
          <view style="padding: 16rpx; background: #f6ffed; border: 2rpx solid #b7eb8f; border-radius: 8rpx; margin-bottom: 20rpx; font-size: 26rpx; color: #52c41a;">
            将批准全部申请数量
          </view>
        </block>

        <!-- 驳回原因 -->
        <view class="form-group">
          <view class="form-label">驳回原因（驳回时填写）</view>
          <textarea class="form-input" style="height: 100rpx; padding-top: 12rpx;" placeholder="请填写驳回原因" value="{{rejectReason}}" bindinput="onRejectReasonInput" />
        </view>

        <view style="display: flex; gap: 16rpx;">
          <button style="flex: 1;" class="btn-primary" bindtap="onApprove">
            {{approveMode === 'full' ? '全部批准' : '部分批准'}}
          </button>
          <button style="flex: 1; background: #ff4d4f; color: #fff; border-radius: 8rpx;" bindtap="onReject">驳回</button>
        </view>
      </block>

      <block wx:if="{{currentRequest.status === 'rejected'}}">
        <view style="color: #f5222d; margin-top: 12rpx;">
          驳回原因: {{currentRequest.reject_reason}}
        </view>
      </block>

      <button class="btn-default" style="margin-top: 16rpx;" bindtap="closeDialog">关闭</button>
    </view>
  </view>
</view>
