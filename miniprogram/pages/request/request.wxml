<!--
  出库申请页 — 列表 + 创建
-->
<view>
  <!-- Tab 切换 -->
  <view class="filter-bar">
    <view class="filter-item {{tab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">我的申请</view>
    <view class="filter-item {{tab === 'create' ? 'active' : ''}}" bindtap="switchTab" data-tab="create">提交申请</view>
  </view>

  <!-- 申请列表 -->
  <block wx:if="{{tab === 'list'}}">
    <!-- 状态筛选 -->
    <view class="filter-bar" style="border-bottom: none;">
      <view class="filter-item {{statusFilter === '' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="">全部</view>
      <view class="filter-item {{statusFilter === 'pending' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="pending">待审批</view>
      <view class="filter-item {{statusFilter === 'approved' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="approved">已通过</view>
      <view class="filter-item {{statusFilter === 'rejected' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="rejected">已驳回</view>
    </view>

    <view wx:for="{{items}}" wx:key="_id" class="card">
      <view style="display: flex; justify-content: space-between; align-items: center;">
        <view class="tag tag-{{item.status}}">{{item.statusLabel}}</view>
        <text style="font-size: 24rpx; color: #999;">{{item.createdAtText}}</text>
      </view>
      <view style="margin-top: 12rpx;">
        <view wx:for="{{item.items}}" wx:for-item="sub" wx:key="part_no" style="font-size: 26rpx; color: #666;">
          {{sub.part_name}} x {{sub.quantity}}
        </view>
      </view>
      <view style="font-size: 24rpx; color: #999; margin-top: 8rpx;">项目: {{item.project_location}}</view>

      <!-- 操作按钮 -->
      <view wx:if="{{item.status === 'pending'}}" style="margin-top: 16rpx; text-align: right;">
        <button size="mini" class="btn-danger" bindtap="onCancel" data-id="{{item._id}}" style="font-size: 24rpx;">撤回</button>
      </view>
    </view>

    <view wx:if="{{!loading && items.length === 0}}" class="empty">
      <view class="empty-text">暂无申请记录</view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </block>

  <!-- 提交申请 -->
  <block wx:if="{{tab === 'create'}}">
    <view class="container">
      <view class="card">
        <view class="card-title">申请出库</view>

        <!-- 项目地点 -->
        <view class="form-group">
          <view class="form-label">项目地点 *</view>
          <input class="form-input" placeholder="请输入项目地点" value="{{projectLocation}}" bindinput="onProjectInput" />
        </view>

        <!-- 备件明细 -->
        <view class="form-label">备件明细</view>
        <view wx:for="{{formItems}}" wx:key="index" style="display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx;">
          <picker style="flex: 2;" mode="selector" range="{{partTypes}}" range-key="part_name" bindchange="onPartSelect" data-idx="{{index}}">
            <view class="form-input" style="line-height: 80rpx;">
              {{item._part_name || '选择备件'}}
            </view>
          </picker>
          <input class="form-input" style="flex: 1;" type="number" placeholder="数量" value="{{item.quantity}}" bindinput="onQtyInput" data-idx="{{index}}" />
          <view wx:if="{{formItems.length > 1}}" bindtap="removeItem" data-idx="{{index}}" style="color: #f5222d; padding: 0 8rpx;">删</view>
        </view>

        <view style="margin-bottom: 24rpx;">
          <button size="mini" class="btn-default" bindtap="addItem">+ 添加备件</button>
        </view>

        <!-- 备注 -->
        <view class="form-group">
          <view class="form-label">备注</view>
          <textarea class="form-input" style="height: 120rpx; padding-top: 16rpx;" placeholder="可选" value="{{remark}}" bindinput="onRemarkInput" />
        </view>

        <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '提交申请'}}
        </button>
      </view>
    </view>
  </block>
</view>
