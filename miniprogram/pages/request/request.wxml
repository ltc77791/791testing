<!--
  出库申请页 — 列表 + 创建
-->
<view>
  <!-- Tab 切换 -->
  <view class="filter-bar">
    <view class="filter-item {{tab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">{{isOperator ? '我的申请' : '申请详情'}}</view>
    <view wx:if="{{isOperator}}" class="filter-item {{tab === 'create' ? 'active' : ''}}" bindtap="switchTab" data-tab="create">提交申请</view>
  </view>

  <!-- 非操作员提示 -->
  <view wx:if="{{!isOperator}}" style="padding: 24rpx; text-align: center; color: #999; font-size: 26rpx;">
    审批角色不可提交申请，如需申请请使用操作员账号
  </view>

  <!-- 申请列表 -->
  <block wx:if="{{tab === 'list'}}">
    <!-- 状态筛选 -->
    <view class="filter-bar" style="border-bottom: none;">
      <view class="filter-item {{statusFilter === '' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="">全部</view>
      <view class="filter-item {{statusFilter === 'pending' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="pending">待审批</view>
      <view class="filter-item {{statusFilter === 'approved' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="approved">已通过</view>
      <view class="filter-item {{statusFilter === 'rejected' ? 'active' : ''}}" bindtap="onStatusFilter" data-status="rejected">已驳回</view>
    </view>

    <view wx:for="{{items}}" wx:key="_id" class="card" bindtap="onTapRequest" data-id="{{item._id}}">
      <!-- 头部: 审批结果 + 申请人 -->
      <view class="card-header">
        <text class="card-applicant">{{item.applicant}}</text>
        <view class="tag tag-{{item.status}}">{{item.statusLabel}}</view>
      </view>

      <!-- 备件明细表格 -->
      <view class="item-table">
        <view class="item-table-head">
          <text class="col-no">备件编号</text>
          <text class="col-name">备件名称</text>
          <text class="col-qty">申请</text>
          <text class="col-qty" wx:if="{{item.status === 'approved'}}">审批</text>
        </view>
        <view wx:for="{{item.displayItems}}" wx:for-item="sub" wx:key="part_no" class="item-table-row">
          <text class="col-no">{{sub.part_no}}</text>
          <text class="col-name">{{sub.part_name}}</text>
          <text class="col-qty">{{sub.quantity}}</text>
          <text class="col-qty {{sub.approved_quantity < sub.quantity ? 'partial-qty' : ''}}" wx:if="{{item.status === 'approved'}}">{{sub.approved_quantity != null ? sub.approved_quantity : sub.quantity}}</text>
        </view>
      </view>

      <!-- 底部: 审批人 + 撤回按钮 -->
      <view class="card-footer" wx:if="{{item.approved_by || (item.status === 'pending' && item.applicant === currentUser)}}">
        <text class="card-meta" wx:if="{{item.approved_by}}">审批人: {{item.approved_by}}</text>
        <view wx:if="{{item.status === 'pending' && item.applicant === currentUser}}" style="margin-left: auto;">
          <button size="mini" class="btn-danger" catchtap="onCancel" data-id="{{item._id}}" style="font-size: 24rpx;">撤回</button>
        </view>
      </view>
    </view>

    <view wx:if="{{!loading && items.length === 0}}" class="empty">
      <view class="empty-text">暂无申请记录</view>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </block>

  <!-- 提交申请 -->
  <block wx:if="{{tab === 'create'}}">
    <view class="container">
      <view class="card">
        <view class="card-title">申请出库</view>

        <!-- 项目号 -->
        <view class="form-group">
          <view class="form-label">项目号 *</view>
          <picker mode="selector" range="{{projectOptions}}" bindchange="onProjectSelect">
            <view class="form-input" style="line-height: 80rpx;">
              {{projectNo || '请选择项目号'}}
            </view>
          </picker>
        </view>

        <!-- 项目地点 -->
        <view class="form-group">
          <view class="form-label">项目地点 *</view>
          <input class="form-input" placeholder="请输入项目地点" value="{{projectLocation}}" bindinput="onProjectInput" />
        </view>

        <!-- 出库原因 -->
        <view class="form-group">
          <view class="form-label">出库原因 *</view>
          <picker mode="selector" range="{{reasonOptions}}" bindchange="onReasonSelect">
            <view class="form-input" style="line-height: 80rpx;">
              {{outboundReason || '请选择出库原因'}}
            </view>
          </picker>
        </view>

        <!-- 备件明细 -->
        <view class="form-label">备件明细</view>
        <view wx:for="{{formItems}}" wx:key="index" style="display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx;">
          <picker style="flex: 2;" mode="selector" range="{{partTypes}}" range-key="displayName" bindchange="onPartSelect" data-idx="{{index}}">
            <view class="form-input" style="line-height: 80rpx;">
              {{item._part_label || '选择备件'}}
            </view>
          </picker>
          <input class="form-input" style="flex: 1;" type="number" placeholder="数量" value="{{item.quantity}}" bindinput="onQtyInput" data-idx="{{index}}" />
          <view wx:if="{{formItems.length > 1}}" bindtap="removeItem" data-idx="{{index}}" style="color: #f5222d; padding: 0 8rpx;">删</view>
        </view>

        <view style="margin-bottom: 24rpx;">
          <button size="mini" class="btn-default" bindtap="addItem">+ 添加备件</button>
        </view>

        <!-- 备注 -->
        <view class="form-group">
          <view class="form-label">备注</view>
          <textarea class="form-input" style="height: 120rpx; padding-top: 16rpx;" placeholder="可选" value="{{remark}}" bindinput="onRemarkInput" />
        </view>

        <button class="btn-primary" bindtap="onSubmit" disabled="{{submitting}}">
          {{submitting ? '提交中...' : '提交申请'}}
        </button>
      </view>
    </view>
  </block>

  <!-- 申请详情弹窗 -->
  <view wx:if="{{showDetailDialog}}" class="dialog-mask" bindtap="closeDetail">
    <view class="dialog-content" catchtap="noop" style="max-height: 85vh; overflow-y: auto;">
      <view class="card-title">申请详情</view>

      <!-- 基本信息 -->
      <view class="result-info">
        <view class="result-row">
          <text class="result-label">申请人</text>
          <text class="result-value">{{detailRequest.applicant}}</text>
        </view>
        <view class="result-row">
          <text class="result-label">审批人</text>
          <text class="result-value">{{detailRequest.approved_by || '-'}}</text>
        </view>
        <view class="result-row">
          <text class="result-label">审批结果</text>
          <view class="result-value">
            <view wx:if="{{detailRequest.status === 'approved'}}" class="tag tag-approved">
              {{detailRequest.approval_type === 'partial' ? '部分通过' : '全量通过'}}
            </view>
            <view wx:elif="{{detailRequest.status === 'rejected'}}" class="tag tag-rejected">已驳回</view>
            <view wx:elif="{{detailRequest.status === 'cancelled'}}" class="tag tag-cancelled">已撤回</view>
            <view wx:else class="tag tag-pending">待审批</view>
          </view>
        </view>
        <view class="result-row" wx:if="{{detailRequest.status === 'rejected' && detailRequest.reject_reason}}">
          <text class="result-label">驳回原因</text>
          <text class="result-value reject-text">{{detailRequest.reject_reason}}</text>
        </view>
      </view>

      <!-- 备件明细 -->
      <view class="result-table">
        <view class="result-table-head">
          <text class="rcol-no">备件编号</text>
          <text class="rcol-name">备件名称</text>
          <text class="rcol-qty">申请</text>
          <text class="rcol-qty" wx:if="{{detailRequest.status === 'approved'}}">审批</text>
        </view>
        <view wx:for="{{detailItems}}" wx:for-item="sub" wx:key="part_no" class="result-table-row">
          <text class="rcol-no">{{sub.part_no}}</text>
          <text class="rcol-name">{{sub.part_name}}</text>
          <text class="rcol-qty">{{sub.quantity}}</text>
          <text class="rcol-qty {{sub.approved_quantity < sub.quantity ? 'partial-qty' : ''}}" wx:if="{{detailRequest.status === 'approved'}}">{{sub.approved_quantity != null ? sub.approved_quantity : sub.quantity}}</text>
        </view>
      </view>

      <button class="btn-default" style="margin-top: 24rpx;" bindtap="closeDetail">关闭</button>
    </view>
  </view>
</view>
